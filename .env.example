# ── LLM Configuration ─────────────────────────────────────────────────────────
# Use "https://api.openai.com/v1" for OpenAI
# Use "http://localhost:11434/v1" for local Ollama
# Use "http://localhost:1234/v1" for LM Studio
# Use "https://<resource>.openai.azure.com" for Azure OpenAI (also set OPENAI_API_VERSION)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Set this to use Azure OpenAI; leave blank for standard OpenAI / local models
# e.g. 2024-02-01
OPENAI_API_VERSION=

# ── OCR Configuration ─────────────────────────────────────────────────────────
# Leave blank to use built-in OCR, or set to a remote DocTR/PaddleOCR service URL
REMOTE_OCR_URL=

# ── Vision Model ──────────────────────────────────────────────────────────────
# Used for photo detection and image description.
# For Ollama: e.g. llama3.2-vision:11b
# For LM Studio / OpenAI: use the same model as LLM_MODEL if it supports vision
VISION_MODEL=llama3.2-vision:11b
VISION_ENABLED=true

# ── LLM Context Window (Ollama only) ──────────────────────────────────────────
# Only applies when using Ollama. For LM Studio or OpenAI, set context length
# in the server/platform settings instead.
LLM_NUM_CTX=8192

# ── Admin Authentication ──────────────────────────────────────────────────────
# Set both to enable HTTP Basic Auth on admin endpoints. Leave blank to disable.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ALLOW_USER_TRAINING=true
DEBUG_MODE=false
