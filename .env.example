# ── LLM Configuration ─────────────────────────────────────────────────────────
# Use "https://api.openai.com/v1" for OpenAI, or "http://localhost:11434/v1" for local Ollama
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# ── OCR Configuration ─────────────────────────────────────────────────────────
# Leave blank to use built-in OCR, or set to a remote DocTR/PaddleOCR service URL
REMOTE_OCR_URL=

# ── Vision Model ──────────────────────────────────────────────────────────────
# Used for photo detection and image description (Ollama local model)
VISION_MODEL=llama3.2-vision:11b
VISION_ENABLED=true

# ── LLM Context Window ────────────────────────────────────────────────────────
# 8192 handles most multi-page documents. Increase for very long documents.
LLM_NUM_CTX=8192

# ── Admin Authentication ──────────────────────────────────────────────────────
# Set both to enable HTTP Basic Auth on admin endpoints. Leave blank to disable.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ALLOW_USER_TRAINING=true
DEBUG_MODE=false
